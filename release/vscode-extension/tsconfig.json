{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "vscode"],
    "baseUrl": ".",
    "paths": {
      "typescript2mermaid-lib": ["../index.ts"],
      "ts-morph": ["./node_modules/ts-morph"]
    }
  },
  "include": ["src"]
}
