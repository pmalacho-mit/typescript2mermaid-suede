{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "release",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["release"],
  // The VS Code extension is a separate build with its own tsconfig (it maps
  // `typescript2mermaid-lib` to ../index.ts and bundles via esbuild), so it
  // must not be typechecked as part of the library.
  "exclude": ["release/vscode-extension"]
}
